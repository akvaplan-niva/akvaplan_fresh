{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run --unstable-hmr --unstable-cron --unstable-kv --allow-sys --allow-ffi --env --allow-env --allow-read --allow-write --allow-run --allow-net --allow-import dev.ts",
    "seed": "deno run --allow-env --env-file -N ./kv/jobs/seed.ts",
    "preview": "DENO_DEPLOYMENT_ID=\"$(git rev-parse HEAD)\" deno run -A main.ts",
    "icons": "deno run --allow-net=fonts.gstatic.com --allow-read=static --allow-write=. tasks.ts icons",
    "build": "deno run --unstable-kv --allow-sys --allow-ffi --env --allow-env --allow-read --allow-write --allow-run --allow-net --allow-import dev.ts build",
    "kv-seed": "deno run --unstable-kv --env --allow-env --allow-net --allow-read=kv/seed/manifest --allow-write=kv/seed/manifest kv/jobs/seed.ts",
    "kv-list": "deno run --unstable-kv --env --allow-env --allow-net kv/jobs/list.ts"
  },
  "compilerOptions": { "jsx": "react-jsx", "jsxImportSource": "preact" },
  "imports": {
    "akvaplan_fresh/": "./",
    "@/": "./",
    "$fresh/": "https://deno.land/x/fresh@1.7.3/",
    "@deno/kv-utils": "jsr:@deno/kv-utils@^0.1.4",
    "@std/assert": "jsr:@std/assert@1",
    "preact": "npm:preact@10.29.2",
    "preact-render-to-string": "npm:preact-render-to-string@6.7.0",
    "@preact/signals": "npm:@preact/signals@1.3.0",
    "@preact/signals-core": "npm:@preact/signals-core@1.8.0",
    "@deno/kv-oauth": "jsr:@deno/kv-oauth@0.11.0",
    "@hyperjump/json-pointer": "npm:@hyperjump/json-pointer@1.1.0",
    "@orama/orama": "npm:@orama/orama@3.1.18",
    "@orama/plugin-data-persistence": "npm:@orama/plugin-data-persistence@3.1.18",
    "@orama/stemmers": "npm:@orama/stemmers@^3.1.18",
    "@std/async": "jsr:@std/async@1.0.10",
    "@std/encoding": "jsr:@std/encoding@1.0.7",
    "@std/http": "jsr:@std/http@1",
    "@std/ulid": "jsr:@std/ulid@1",
    "@valibot/valibot": "jsr:@valibot/valibot@0.30.0",
    "accept-language-parser": "npm:accept-language-parser@1.5.0",
    "open-props": "npm:open-props@1.7.12",
    "sanitize-html": "npm:sanitize-html@^2.17.0",
    "showdown": "npm:showdown@^2.1.0",
    "slug": "https://deno.land/x/slug@v1.1.0/mod.ts",
    "tailwindcss": "npm:tailwindcss@3.4.19",
    "turndown": "npm:turndown@7.2.4"
  },
  "scopes": {},
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*"],
  "unstable": [
    "kv",
    "cron"
  ]
}
